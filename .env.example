# Yalnız Search Console'un HTML etiketi yöntemini kullanırsanız doldurun.
# Tam meta etiketini değil, content="..." içindeki değeri yazın.
# Alan adı + DNS doğrulamasında bu değişken gerekli değildir.
GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster > Erişim hakları > Meta etiketi içindeki content değeri.
YANDEX_SITE_VERIFICATION=

# Bing Webmaster Tools > HTML Meta Tag içindeki msvalidate.01 content değeri.
BING_SITE_VERIFICATION=

# İsteğe bağlı Web Vitals alıcısı; yalnız site içi bir yol kabul edilir.
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=
